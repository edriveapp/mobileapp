{
    "name": "edrive-backend",
    "version": "0.0.1",
    "description": "Edrive Backend API",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true }); require('fs').rmSync('tsconfig.tsbuildinfo', { force: true });\"",
        "build": "npm run clean && nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main.js",
        "start:prod:migrate": "typeorm migration:run -d dist/data-source.js && node dist/main.js",
        "postprebuild": "sed -i '' 's/prepare_react_native_project!/prepare_react_native_project!\\nuse_modular_headers!/' ios/Podfile && cd ios && pod install",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "migration:generate": "npm run build && typeorm migration:generate -d dist/data-source.js",
        "migration:run": "npm run build && typeorm migration:run -d dist/data-source.js",
        "migration:revert": "npm run build && typeorm migration:revert -d dist/data-source.js",
        "migration:show": "npm run build && typeorm migration:show -d dist/data-source.js",
        "migration:generate:local": "npm run build && cross-env DATABASE_URL=$DATABASE_PUBLIC_URL typeorm migration:generate -d dist/data-source.js",
        "migration:run:local": "npm run build && cross-env DATABASE_URL=$DATABASE_PUBLIC_URL typeorm migration:run -d dist/data-source.js",
        "migration:revert:local": "npm run build && cross-env DATABASE_URL=$DATABASE_PUBLIC_URL typeorm migration:revert -d dist/data-source.js",
        "migration:show:local": "npm run build && cross-env DATABASE_URL=$DATABASE_PUBLIC_URL typeorm migration:show -d dist/data-source.js",
        "admin:create:prod": "cross-env DATABASE_URL=$DATABASE_PUBLIC_URL npx ts-node scripts/create-admin.ts"
    },
    "dependencies": {
        "@nestjs/axios": "^4.0.1",
        "@nestjs/common": "^10.0.0",
        "@nestjs/config": "^3.3.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/platform-socket.io": "^10.0.0",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/serve-static": "^4.0.2",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/typeorm": "^10.0.0",
        "@nestjs/websockets": "^10.0.0",
        "@types/multer": "^2.1.0",
        "@types/nodemailer": "^7.0.11",
        "@types/passport-jwt": "^4.0.1",
        "axios": "^1.13.5",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "expo-document-picker": "^14.0.8",
        "firebase-admin": "^13.6.1",
        "geojson": "^0.5.0",
        "ioredis": "^5.10.1",
        "nodemailer": "^8.0.4",
        "octicons": "^8.4.2",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "redis": "^4.0.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "socket.io": "^4.0.0",
        "twilio": "^5.12.1",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/schematics": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^4.17.17",
        "@types/geojson": "^7946.0.16",
        "@types/jest": "^29.5.2",
        "@types/node": "^20.3.1",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "cross-env": "^10.1.0",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.5.0",
        "prettier": "^3.0.0",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
