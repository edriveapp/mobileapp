# ─────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL and REDIS_URL automatically
# when PostgreSQL / Redis services are linked to your deployment.
# Do NOT set these manually in Railway — let them be auto-injected.
# ─────────────────────────────────────────────────────────────

# PostgreSQL — auto-injected by Railway (linked Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Public Postgres URL — only needed for running migrations from your local machine
# Get this from: Railway Dashboard → Postgres → Variables → DATABASE_PUBLIC_URL
DATABASE_PUBLIC_URL=postgresql://user:password@roundhouse.proxy.rlwy.net:PORT/railway

# Redis — auto-injected by Railway (linked Redis service)
REDIS_URL=redis://default:password@host:6379

# ─── Auth ─────────────────────────────────────────────────────
# REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# ─── CORS ─────────────────────────────────────────────────────
# REQUIRED — comma-separated list of allowed origins (your app's URL + any web dashboard)
# Example: https://edrive.app,https://admin.edrive.app
# Leave empty to block all browser/WebSocket origins (mobile-only is fine without it)
ALLOWED_ORIGINS=https://your-app.up.railway.app,https://your-admin-dashboard.com

# ─── App ──────────────────────────────────────────────────────
# REQUIRED — used as the Paystack payment callback URL
APP_URL=https://your-service.up.railway.app

# ─── Paystack ─────────────────────────────────────────────────
# REQUIRED — get from Paystack Dashboard → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx

# ─── SMTP (Nodemailer) ────────────────────────────────────────
# REQUIRED for OTP emails, driver verification emails, refund emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@edrive.ng




# ─── Email Provider for support ─────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
EMAIL_FROM=support@edriveapp.com

# ─── OSRM (Route Calculation) ─────────────────────────────────
# Optional — defaults to http://localhost:5000 if not set
# Use a hosted OSRM instance or Project OSRM's demo server (rate-limited)
# Example self-hosted: https://osrm.yourdomain.com
OSRM_URL=http://router.project-osrm.org

# ─── Admin Account Bootstrap ──────────────────────────────────
# Only used when running: npx ts-node scripts/create-admin.ts
# Not read at runtime — safe to leave unset in production
ADMIN_EMAIL=admin@edrive.com
ADMIN_PASSWORD=

# ─── Cloudinary (Driver Document / File Storage) ──────────────────────────────
# REQUIRED in production — Railway filesystem is ephemeral, local uploads are lost on deploy.
# Sign up free at https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Firebase (Push Notifications fallback) ───────────────────
# Optional — only needed if using Firebase instead of Expo push
FIREBASE_PROJECT_ID=

# ─── Twilio (SMS OTP — not currently wired in main flow) ──────
# Optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Railway sets PORT automatically — do not override
# PORT=3000
