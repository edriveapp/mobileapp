# ─────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL and REDIS_URL automatically
# when PostgreSQL / Redis services are linked to your deployment.
# Do NOT set these manually in Railway — let them be auto-injected.
# ─────────────────────────────────────────────────────────────

# PostgreSQL — auto-injected by Railway (linked Postgres service)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Public Postgres URL — only needed for running migrations from your local machine
# Get this from: Railway Dashboard → Postgres → Variables → DATABASE_PUBLIC_URL
DATABASE_PUBLIC_URL=postgresql://user:password@roundhouse.proxy.rlwy.net:PORT/railway

# Redis — auto-injected by Railway (linked Redis service)
REDIS_URL=redis://default:password@host:6379

# App — set to your Railway public domain (used for Paystack callback URL)
APP_URL=https://your-service.up.railway.app

# Auth
JWT_SECRET=replace-with-a-strong-random-secret

# Google Maps
GOOGLE_MAPS_API_KEY=

# Paystack
PAYSTACK_SECRET_KEY=

# Firebase
FIREBASE_PROJECT_ID=

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Railway sets this automatically - do not override
# PORT=
